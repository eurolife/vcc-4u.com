---
// Import the necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import { SITE } from '@data/constants';
import TestimonialsSectionAlt from '@components/sections/testimonials/TestimonialsSectionAlt.astro';
import ScottJacobs from '@images/scottjacobs.jpg';
import ColinStanley from '@images/colinstanley.jpg';
import KevinDibben from '@images/kevindibben.jpg';
import HaydenClaisse from '@images/haydenclaisse.jpg';
import Janet from '@images/janet.jpg';
import JimmyDelshad from '@images/jimmydelshad.jpg';
import RomeoElias from '@images/romeoelias.jpg';

const pageTitle: string = `Testimonials | ${SITE.title}`;

// Testimonial data that will be rendered in the component
const testimonials = [
  // First testimonial data
  {
    content:
      ' "I have worked with Paul for several years. He is a very knowledgeable professional in all facets of business. He is particularly successful at setting up accounting and financial systems, setting financial goals, and overseeing ongoing financial performance. Paul\'s engineering skills and background are reflected in his technical expertise and in his systematic and thoughtful approach to business issues. I am happy to recommend Paul." ',
    author: 'Scott Jacobs',
    role: 'ISC Electronic Systems',
    avatarSrc: ScottJacobs.src,
    avatarAlt: 'Scott Jacobs',
  },
  // Second testimonial data
  {
    content:
      ' "A pleasure to work with, a true professional. With a solid engineering background and his management skills, we had an excellent working relationship, with good communications, and very satisfying results." ',
    author: 'Colin Stanley',
    role: 'CEO at Two Point Seven Inc',
    avatarSrc: ColinStanley.src,
    avatarAlt: 'Colin Stanley',
  },
  // Third testimonial data
  {
    content:
      ' "I hired Paul as a business consultant to advise me on a start up real estate and development company. His insight and advice is incredible. Paul has the ability to see the big picture and to cut straight to the heart of every issue. I would recommend Paul without any reservation." ',
    author: 'Kevin Dibben',
    role: 'Real Estate Broker, Realtor, On',
    avatarSrc: KevinDibben.src,
    avatarAlt: 'Kevin Dibben',
  },
  {
    content:
      ' "Paul and I were members of the same CEO Roundtable. Paul has a very broad knowledge of business and a strong entrepreneurial spirit. He was able to engage roundtable members on their issues effectively. He has done the same with a wide variety of clients as a consultant. He clearly can analyze business situations as to the source of their profits, their leverage points, and identify ways to improve profitablility quickly." ',
    author: 'Hayden Claisse',
    role: 'FACILITATOR at XLN (Executive Leadership Network)',
    avatarSrc: HaydenClaisse.src,
    avatarAlt: 'Hayden Claisse',
  },
  {
    content:
      ' "Paul has outstanding strategic insight. His ability to help an organization identify challenges and offer solutions that will increase profitability have been helpful to many organizations he has worked with, including mine." ',
    author: 'Janet McCracken Beard',
    role: 'CEO  The Employers Edge',
    avatarSrc: Janet.src,
    avatarAlt: 'Janet McCracken Beard',
  },

  {
    content:
      ' "Paul worked for me at Ai and did a great job. He is very trustworthy and dependable." ',
    author: 'Jimmy Delshad',
    role: 'President @ AI Business Technologies and Two-Time Mayor of Beverly Hills | Global Ambassador of Cedars Sinai',
    avatarSrc: JimmyDelshad.src,
    avatarAlt: 'Jimmy Delshad',
  },
  {
    content:
      ' "I had the pleasure to engage Paul to help me with a business acquisition. His attention to details, rapid focus on the salient issues, and deep analysis of the company’s data and kpis were instrumental in helping me expedite and complete due diligence and close on the loan. I found Paul to be very helpful by my side, experienced, business savvy and a versatile advisor helping me evaluate and think through all aspects of this new business. I highly recommend him." ',
    author: 'Romeo Elias',
    role: 'Founder of Intellect',
    avatarSrc: RomeoElias.src,
    avatarAlt: 'Romeo Elias',
  },
];
---

<!--Utilizing MainLayout for the outer layout of the page, and defining meta for SEO purposes-->
<MainLayout
  title={pageTitle}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://vcc-4u.com/testimonials',
    url: 'https://vcc-4u.com/testimonials',
    name: 'Testimonials | Value Creation Consulting',
    description: 'What our clients are saying.',
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://vcc-4u.com',
      name: 'Value Creation Consulting',
      description:
        'Value Creation Consulting helps small business owners transform their business from a job into a wealth-building asset.',
    },
    inLanguage: 'en-US',
  }}
>
  <!--Testimonials section-->
  <TestimonialsSectionAlt
    title="What Clients Say"
    testimonials={testimonials}
  />
</MainLayout>
