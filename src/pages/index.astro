---
// Import the necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import HeroSection from '@components/sections/landing/HeroSection.astro';
import FeaturesGeneral from '@components/sections/features/FeaturesGeneral.astro';
import heroImage from '@images/homebanner.jpg';
import herobg from '@images/herobg.png';
import features from '@data/features.json';
import features2 from '@data/features2.json';
import features3 from '@data/features3.json';
import features4 from '@data/features4.json';
import featureImage1 from '@images/selling.jpg';
import featureImage2 from '@images/buying.jpg';
import featureImage3 from '@images/mentor.jpg';
import featureImage4 from '@images/experience.jpg';
import FeaturesStatsAlt from '@/components/sections/features/FeaturesStatsAlt.astro';
import HeroSectionAlt from '@/components/sections/landing/HeroSectionAlt.astro';
import HeroSectionNew from '@/components/sections/landing/HeroSectionNew.astro';

const avatarSrcs: Array<string> = [
  'https://images.unsplash.com/photo-1568602471122-7832951cc4c5?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80',
  'https://images.unsplash.com/photo-1531927557220-a9e23c1e4794?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80',
  'https://images.unsplash.com/photo-1541101767792-f9b2b1c4f127?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&&auto=format&fit=facearea&facepad=3&w=300&h=300&q=80',
  'https://images.unsplash.com/photo-1492562080023-ab3db95bfbce?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80',
];
---

<MainLayout>
  <HeroSection
    title="Grow. Scale. Exit."
    subTitle="Helping Small Business Owners Exit or Grow by Acquisition or Organically"
    primaryBtn="Our Expertise"
    primaryBtnURL="/expertise"
    secondaryBtn="Contact VCC"
    secondaryBtnURL="/contact"
    withReview={false}
    avatars={avatarSrcs}
    rating=``
    starCount={4}
    reviews=``
    src={heroImage}
    bgimg={herobg}
    alt="Project management image"
  />

  <FeaturesGeneral
    title="Selling"
    subTitle="Turning your business into a strategic, de-risked asset buyers compete for."
    features={features}
    src={featureImage1}
    alt="Selling"
  />
  <hr class="border-t border-dotted border-neutral-500" />
  <FeaturesGeneral
    title="Buying"
    subTitle="A quality purchase takes selecting the right business."
    src={featureImage2}
    alt="Buying"
    features={features2}
  />
  <hr class="border-t border-dotted border-neutral-500" />
  <FeaturesGeneral
    title="Mentoring"
    subTitle="Foster productivity, engagement, empowerment, and growth."
    src={featureImage3}
    alt="Mentor Management"
    features={features3}
  />
  <hr class="border-t border-dotted border-neutral-500" />
  <FeaturesGeneral
    title="Why Work with VCC?"
    subTitle=""
    src={featureImage4}
    alt="Business Management"
    features={features4}
  />
  <FeaturesStatsAlt
    title="Take the Next Step Toward Business Success"
    subTitle="VCC is here to help you"
    benefits={['scale', 'optimize profitability, and', 'maximize exit value.']}
  />

  <HeroSectionAlt
    title="Let’s talk about how we can help your business thrive."
    subTitle=""
    btnTitle="Contact Us Today"
    url="contact"
  />
</MainLayout>
