---
// Import the necessary dependencies
import { Image } from 'astro:assets';
import PrimaryCTA from '@components/ui/buttons/PrimaryCTA.astro';
import SecondaryCTA from '@components/ui/buttons/SecondaryCTA.astro';
import ReviewComponent from '@components/ui/blocks/ReviewComponent.astro';
import HeroBg from '@images/herobg.png';

// Define props from Astro
const {
  title,
  subTitle,
  primaryBtn,
  primaryBtnURL,
  secondaryBtn,
  secondaryBtnURL,
  withReview,
  avatars,
  starCount,
  rating,
  reviews,
  src,
  alt,
  bgimg,
} = Astro.props;

// Define TypeScript interface for props
interface Props {
  title: string;
  subTitle?: string;
  primaryBtn?: string;
  primaryBtnURL?: string;
  secondaryBtn?: string;
  secondaryBtnURL?: string;
  withReview?: boolean;
  avatars?: Array<string>;
  starCount?: number;
  rating?: string;
  reviews?: string;
  src?: any;
  alt?: string;
  bgimg?: any;
}
---

<!-- Defining a grid container that holds all the content -->
<section
  class="relative mx-auto max-w-[85rem] px-4 pt-14 sm:px-6 md:items-center lg:px-8 2xl:max-w-full rounded-xl bg-none md:bg-contain bg-no-repeat [background-position:right_top_3rem] w-full"
>
  <!-- Title and description -->
  <div>
    <Image
      src={HeroBg}
      alt="grow scale exit image"
      class="hidden md:block w-[300px] absolute right-0 top-16 xl:w-[400px] xl:top-10"
    />
    <!-- Each h1 and p tag renders a portion of the title and subTitle defined above -->
    <h1
      class="block text-balance text-2xl font-logo tracking-tight text-neutral-800 dark:text-neutral-200 sm:text-3xl lg:text-5xl lg:leading-tight text-center md:text-left"
    >
      <!-- About Fragment: https://docs.astro.build/en/basics/astro-syntax/#fragments -->
      <Fragment set:html={title} />
    </h1>
    {
      subTitle && (
        <p class="mt-3 text-pretty text-center md:text-left text-lg md:text-2xl leading-relaxed text-neutral-500 dark:text-neutral-400 md:w-1/2 lg:w-2/3 xl:w-4/5">
          {subTitle}
        </p>
      )
    }
    <p
      class="mt-3 text-pretty text-center md:text-left md:text-lg leading-relaxed text-neutral-700 dark:text-neutral-400 md:w-1/2 lg:w-2/3 xl:w-4/5"
    >
      Attract the right buyers, Find the right company, strengthen the
      management team.
    </p>
    <!-- Action Button Section: This section includes two CTAs with their own styles and URL -->
    <div
      class="mt-7 grid w-full gap-3 sm:flex sm:justify-center md:justify-start"
    >
      {primaryBtn && <PrimaryCTA title={primaryBtn} url={primaryBtnURL} />}
      {
        secondaryBtn && (
          <SecondaryCTA title={secondaryBtn} url={secondaryBtnURL} />
        )
      }
    </div>
  </div>
  <!-- Hero Image Section -->
</section>
